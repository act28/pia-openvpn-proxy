#!/bin/sh
set -e -u -o pipefail

[ "$VPN_PROTOCOL" != "openvpn" ] && exit 0

# Exit if interface is already up.
ip link show tun0 >/dev/null 2>&1 && exit 0

[ ! -d /app/ovpn/config ] && mkdir -p /app/ovpn/config
# Download and install the latest ovpn configs
# This uses UDP & AES-256-GCM
PIA_OVPN_CONFIG_URL='https://www.privateinternetaccess.com/openvpn/openvpn-strong.zip'
curl -s $PIA_OVPN_CONFIG_URL -o pia_ovpn_configs.zip || (echo "ERROR: Failed to download PIA configuration files, exiting" && exit 1)
unzip -uoq pia_ovpn_configs.zip -d /app/ovpn/config

# copy configs to user mount
mkdir -p /config/pia
cp -u /app/ovpn/config/*.ovpn /config/pia/
rm -f /app/ovpn/config/*

if [ -n "$UID" -a -n "$GID" ]; then
  chown -R "$UID:$GID" /config
fi

if [ -n "$REGION" ]; then
  REGION=$(echo $REGION | sed 's/ /_/g' | tr '[:upper:]' '[:lower:]')
  if [ ! -f "/config/pia/${REGION}.ovpn" ]; then
    echo "ERROR: OpenVPN configuration profile not found, check your REGION environment variable, see the OpenVPN generator in the client control panel for possible choices"
    exit 1
  fi
  set -- "$@" '--config' "/config/pia/${REGION}.ovpn"
else
  echo "REGION environment variable is not set. Exiting."
  exit 1
fi

if [ -n "$USERNAME" -a -n "$PASSWORD" ]; then
  echo "$USERNAME" > auth.conf
  echo "$PASSWORD" >> auth.conf
  chmod 600 auth.conf
  set -- "$@" '--auth-nocache'
  set -- "$@" '--auth-user-pass' 'auth.conf'
else
  echo "OpenVPN credentials not set. Exiting."
  exit 1
fi

# Use stronger ciphers (GCM mode instead of vulnerable CBC)
set -- "$@" '--data-ciphers' 'AES-256-GCM:AES-128-GCM:CHACHA20-POLY1305'
set -- "$@" '--data-ciphers-fallback' 'AES-256-CBC'

# Additional security hardening
set -- "$@" '--auth' 'SHA256'

# Set OpenVPN verb level
set -- "$@" '--verb' '3'

# Allow execution of --up and --down scripts
set -- "$@" '--script-security' '2'

# Create DNS update script for after connection
cat > /tmp/update-dns.sh << 'DNSEOF'
#!/bin/sh
cat > /etc/resolv.conf << EOF
# PIA DNS servers - prevents DNS leaks
# https://helpdesk.privateinternetaccess.com/hc/en-us/articles/46777085837339-Using-PIA-DNS-in-Custom-Configurations
nameserver 10.0.0.242
EOF
chmod 644 /etc/resolv.conf
DNSEOF
chmod +x /tmp/update-dns.sh

# Apply DNS settings after connection is established
set -- "$@" '--up' '/tmp/update-dns.sh'
set -- "$@" '--down' '/tmp/update-dns.sh'

openvpn "$@"
